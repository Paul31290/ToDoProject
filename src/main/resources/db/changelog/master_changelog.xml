<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet id="1" author="postgres">
    
    	<!-- Creation of User entity -->
        <createTable tableName="user">
            <column name="user_id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="password" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <!-- Creation of ToDo entity -->
        
        <createTable tableName="todo">
            <column name="todo_id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="is_done" type="boolean">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <!-- Adding the Foreign Key constraint between User and ToDo -->
        
        <addForeignKeyConstraint baseTableName="todo" baseColumnNames="user_id" constraintName="fk_todo_user_id" referencedTableName="user" referencedColumnNames="user_id" />
        
    </changeSet>
    
    <changeSet id="2" author="postgres">
    
    <addAutoIncrement incrementBy="1" tableName="user" columnName="user_id" columnDataType="bigint" />
    
    <addAutoIncrement incrementBy="1" tableName="todo" columnName="todo_id" columnDataType="bigint" />
    </changeSet>
</databaseChangeLog>